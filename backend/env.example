PORT=5000
MONGODB_URI=your_mongodb_connection_string_here # e.g., mongodb://localhost:27017/mydatabase or your Atlas URI

# OpenAI API Key for AI features (e.g., image generation)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: gpt-image-1-mini (default), gpt-image-1, or gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-1-mini

# Imgur Client ID for image uploads
IMGUR_CLIENT_ID=your_imgur_client_id_here
