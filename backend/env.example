NODE_ENV=development
PORT=5000
MONGODB_URI=your_mongodb_connection_string_here # e.g., mongodb://localhost:27017/mydatabase or your Atlas URI

# Secret used to sign/verify JWTs. Use a long, random string in production.
JWT_SECRET=your_jwt_secret_here
# Optional: how long an issued JWT stays valid
JWT_EXPIRES_IN=24h

# Optional: comma-free URL of the frontend, used for CORS. Defaults to "*" (any origin).
CLIENT_URL=http://localhost:3000

# Optional: winston log level (error, warn, info, http, debug). Defaults to "info" in
# production and "debug" otherwise.
LOG_LEVEL=debug

# OpenAI API Key for AI features (e.g., image generation)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: gpt-image-1-mini (default), gpt-image-1, or gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-1-mini

# Imgur Client ID for image uploads
IMGUR_CLIENT_ID=your_imgur_client_id_here

# Optional: rate limiting (see backend/config/index.js for defaults)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
